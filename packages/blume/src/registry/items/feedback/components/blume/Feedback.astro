---
// Installed by `blume add feedback`. Owned by your project — edit freely.
interface Props {
  question?: string;
}

const { question = "Was this page helpful?" } = Astro.props;
---

<aside class="blume-feedback" data-blume-feedback>
  <span class="blume-feedback__question">{question}</span>
  <span class="blume-feedback__actions">
    <button class="blume-feedback__button" data-value="yes" type="button">
      Yes
    </button>
    <button class="blume-feedback__button" data-value="no" type="button">
      No
    </button>
  </span>
  <span class="blume-feedback__thanks" hidden>Thanks for the feedback!</span>
</aside>

<style>
  .blume-feedback {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 2rem 0;
    padding: 0.85rem 1rem;
    border: 1px solid var(--blume-border);
    border-radius: var(--blume-radius);
    font-size: 0.9rem;
  }
  .blume-feedback__button {
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--blume-border);
    border-radius: var(--blume-radius);
    background: var(--blume-background);
    color: inherit;
    cursor: pointer;
  }
  .blume-feedback__button:hover {
    border-color: var(--blume-accent);
  }
</style>

<script>
  for (const root of document.querySelectorAll("[data-blume-feedback]")) {
    const thanks = root.querySelector<HTMLElement>(".blume-feedback__thanks");
    const actions = root.querySelector<HTMLElement>(".blume-feedback__actions");
    for (const button of root.querySelectorAll("[data-value]")) {
      button.addEventListener("click", () => {
        if (actions) {
          actions.hidden = true;
        }
        if (thanks) {
          thanks.hidden = false;
        }
      });
    }
  }
</script>

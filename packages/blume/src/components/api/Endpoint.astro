---
interface Props {
  method: string;
  path: string;
}

const { method, path } = Astro.props;
const normalized = method.toLowerCase();

const methodColor: Record<string, string> = {
  delete: "bg-red-50 text-red-700 dark:bg-red-950/40 dark:text-red-300",
  get: "bg-muted text-foreground",
  patch:
    "bg-amber-50 text-amber-700 dark:bg-amber-950/40 dark:text-amber-300",
  post: "bg-muted text-foreground",
  put: "bg-amber-50 text-amber-700 dark:bg-amber-950/40 dark:text-amber-300",
};
const color = methodColor[normalized] ?? "bg-muted text-foreground";
---

<div
  class="not-prose my-6 flex items-center gap-2.5 rounded-full border border-border bg-background p-2.5"
>
  <span
    class={`rounded-full px-2.5 py-1 font-mono font-semibold text-xs ${color}`}
  >
    {method.toUpperCase()}
  </span>
  <code class="font-mono text-[0.9rem]">{path}</code>
</div>

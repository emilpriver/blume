---
interface Props {
  type?: string;
  title?: string;
}

const { title } = Astro.props;
---

<aside class="custom-callout" data-custom-callout>
  {title && <strong>{title}: </strong>}
  <slot />
</aside>

<style>
  .custom-callout {
    border: 2px dashed var(--blume-accent);
    border-radius: var(--blume-radius);
    padding: 1rem;
    margin: 1.5rem 0;
  }
</style>
